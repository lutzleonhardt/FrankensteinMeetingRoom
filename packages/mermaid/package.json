{
  "name": "mermaid",
  "private": true,
  "type": "module",
  "scripts": {
    "start:standalone:dev": "node build.mjs --dev",
    "build:standalone": "node build.mjs",
    "build:federate": "node build.mjs --federate",
    "build:federate:dev": "node build.mjs --federate --dev",
    "dev": "pnpm build:federate:dev && pnpm start:standalone:dev",
    "clean": "rm -rf dist node_modules/.cache/native-federation"
  },
  "dependencies": {
    "mermaid": "^11.4.1",
    "svelte": "^5.0.0",
    "@softarc/native-federation-orchestrator": "4.0.0"
  },
  "devDependencies": {
    "@frankenstein/shared": "workspace:*",
    "@softarc/native-federation": "^4.1.3",
    "@softarc/native-federation-esbuild": "4.0.0-RC10",
    "esbuild": "^0.25.1",
    "esbuild-svelte": "^0.9.0",
    "svelte-preprocess": "^6.0.0",
    "typescript": "~5.9.2"
  }
}
